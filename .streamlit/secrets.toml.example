# Copy to .streamlit/secrets.toml (gitignored) for local use, or paste into the Streamlit Cloud
# "Secrets" UI for deployment. Everything here is optional and the app runs without any of it,
# but a real deploy for the parents should set app_password + the model + the Sheet.

# --- shared password gate ---
# REQUIRED for a real deploy. Absent/blank = the app is open (local dev only).
app_password = "choose-a-strong-shared-password"

# --- hosted model (free tier) ---
# Local dev uses Ollama via .env; a cloud host has no Ollama, so use a free hosted endpoint.
# Groq is fast with a generous free tier: get a key at https://console.groq.com/keys
LLM_MODEL = "groq/llama-3.3-70b-versatile"
LLM_API_KEY = "gsk_your_groq_key_here"
# LLM_API_BASE is only for self-hosted / custom OpenAI-compatible endpoints; unset for Groq.

# --- Holdings from a published Google Sheet CSV (keyless, auto-loads) ---
# Owner: File -> Share -> Publish to web -> pick the holdings tab -> CSV -> Publish. Paste the
# resulting link here. NOTE: a published link is readable by anyone who has it.
holdings_csv_url = "https://docs.google.com/spreadsheets/d/e/.../pub?gid=0&single=true&output=csv"

# --- Google Sheet as a read+write backend (optional; needs a service-account JSON key) ---
# Blocked by Google 'Secure by Default' on many accounts. If you can create a key, set these;
# otherwise use holdings_csv_url above. The sheet key is the id in /spreadsheets/d/<THIS>/edit.
sheet_key = "<your-sheet-key>"

[gcp_service_account]
type = "service_account"
project_id = "<your-project>"
private_key_id = "<...>"
private_key = "-----BEGIN PRIVATE KEY-----\n<...>\n-----END PRIVATE KEY-----\n"
client_email = "<name>@<your-project>.iam.gserviceaccount.com"
client_id = "<...>"
token_uri = "https://oauth2.googleapis.com/token"
